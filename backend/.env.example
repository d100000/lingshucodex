# LingshuCodex Backend Configuration
# Copy this file to .env and fill in your actual values

# === LLM Gateway ===
# bobdong.cn 是 FireworkRouter 部署的 LLM 网关,支持 OpenAI 协议
LLM_BASE_URL=https://bobdong.cn/v1
LLM_API_KEY=<your-llm-api-key>

# === Server ===
HOST=127.0.0.1
PORT=8020
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET=请在生产环境填写一串足够长的随机字符串
JWT_DAYS=30
ALLOW_REGISTER=true

# === Game Defaults ===
# 默认门派(测试用),正式版玩家自选
DEFAULT_SECT=canglan

# 战斗超时(秒)
LLM_TIMEOUT=60

# 自动重试
LLM_MAX_RETRIES=3          # 最大重试次数
LLM_RETRY_BASE_DELAY=1.0   # 指数退避起点(秒)
LLM_RETRY_MAX_DELAY=8.0    # 单次等待上限

# === 图片生成 (gpt-image-2) ===
IMAGE_BASE_URL=https://bobdong.cn/v1
IMAGE_API_KEY=<your-image-api-key>
IMAGE_MODEL=gpt-image-2
IMAGE_TIMEOUT=120
IMAGE_MAX_RETRIES=3
IMAGE_RETRY_BASE_DELAY=1.5
IMAGE_RETRY_MAX_DELAY=8.0
